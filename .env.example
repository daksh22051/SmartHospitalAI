# Copy this file to .env and fill your real values.
# Docker Compose automatically reads .env from this folder.

# ---- Inference Runtime (MANDATORY for LLM-driven baseline) ----
API_BASE_URL=https://YOUR_ENDPOINT/v1
MODEL_NAME=your_model_name_here
OPENAI_API_KEY=your_openai_api_key_here
# Optional xAI Grok settings.
# If you use Grok, set API_BASE_URL=https://api.x.ai/v1
# and provide GROK_API_KEY.
GROK_API_BASE_URL=https://api.x.ai/v1
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=your_grok_model_here
# Backward-compatible aliases for old configs:
GROQ_API_KEY=
HF_TOKEN=your_hf_token_here

# ---- Live LLM Grader ----
LLM_GRADER_ENDPOINT=https://YOUR_ENDPOINT/v1/chat/completions
LLM_GRADER_API_KEY=your_api_key_here
LLM_GRADER_MODEL=your_grader_model_here

# ---- Live Weather ----
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ---- PPO Training Defaults (optional overrides in your scripts) ----
PPO_LR=0.0001
PPO_GAMMA=0.995
PPO_GAE_LAMBDA=0.97
PPO_CLIP_EPS=0.15
PPO_ENTROPY_COEF=0.002
PPO_VALUE_COEF=0.7
PPO_UPDATE_EPOCHS=6
PPO_MINIBATCH_SIZE=128
PPO_ROLLOUT_STEPS=1024
PPO_MAX_GRAD_NORM=0.5
